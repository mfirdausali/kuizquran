{
  "name": "web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "sync-assets": "cp ../../styles/iman-ui.css public/iman-ui.css && cp ../../public/corpus.json public/corpus.json",
    "predev": "pnpm sync-assets",
    "dev": "vite",
    "prebuild": "pnpm sync-assets",
    "build": "vite build",
    "preview": "vite preview",
    "pages:deploy": "pnpm build && npx wrangler pages deploy dist --project-name iman-quiz",
    "test": "vitest run"
  },
  "dependencies": {
    "engine": "workspace:*",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
